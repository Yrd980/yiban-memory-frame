HOST=0.0.0.0
PORT=8080
YIBAN_DEV_MODE=true
LOG_LEVEL=INFO
DATABASE_URL=postgresql://yiban:yiban@localhost:5432/yiban_memory_frame
REDIS_URL=redis://localhost:6379/0
POSTGRES_PORT=5432
REDIS_PORT=6380
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=yiban
MINIO_SECRET_KEY=yiban-secret
MINIO_SECURE=false
MINIO_BUCKET_PHOTOS=yiban-photos
MINIO_BUCKET_AUDIO=yiban-audio
MODEL_CACHE_DIR=.models
AI_ENABLE_REAL_MODELS=true
AI_ENABLE_DEEPSEEK=true
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.5
DEEPSEEK_MAX_TOKENS=800
SENSEVOICE_MODEL=iic/SenseVoiceSmall
BGE_M3_MODEL=BAAI/bge-m3
SILERO_VAD_REPO=snakers4/silero-vad
